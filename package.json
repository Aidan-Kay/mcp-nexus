{
  "name": "mcp-nexus",
  "version": "1.0.0",
  "description": "Browse-first MCP middleware — an LLM-friendly nexus for discovering and invoking MCP tools across multiple services.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "docker:build": "docker build -t mcp-nexus .",
    "docker:run": "docker run -d --name mcp-nexus -p 8050:8050 -v ./mcp-nexus.yaml:/app/mcp-nexus.yaml mcp-nexus"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@xenova/transformers": "^2.17.2",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "overrides": {
    "sharp": "^0.33.0"
  }
}
